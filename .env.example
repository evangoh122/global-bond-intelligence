# ── SEC EDGAR ────────────────────────────────────────────────────────────────
# Required on every request — missing this causes silent IP bans
EDGAR_USER_AGENT="GlobalBondIntelligence contact@yourdomain.com"

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Optional: needed for gated models or HF Spaces deployment
HF_TOKEN=

# ── Ollama ───────────────────────────────────────────────────────────────────
# Default: http://localhost:11434 (local). Override for remote Ollama instance
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Paths ────────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
SQLITE_DB_PATH=./filings.db
EDGAR_DOWNLOAD_DIR=./data/filings
